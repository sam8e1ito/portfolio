{
    "firestore": {
        "database": "(default)",
        "location": "eur3",
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "hosting": {
        "public": "dist",
        "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
        "rewrites": [
            {
                "source": "!**/*.{pdf,png,jpg,jpeg,svg}",
                "destination": "/index.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "auth": {
        "providers": {}
    }
}
